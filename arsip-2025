local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local function loadExternalUI(url, tag)
    -- Hapus UI lama jika ada
    for _, container in pairs({game.CoreGui, LocalPlayer:WaitForChild("PlayerGui")}) do
        local old = container:FindFirstChild(tag)
        if old then old:Destroy() end
    end

    -- Snapshot sebelum load
    local before = {}
    for _, container in pairs({game.CoreGui, LocalPlayer:WaitForChild("PlayerGui")}) do
        for _, gui in pairs(container:GetChildren()) do
            before[gui] = true
        end
    end

    -- Load UI
    loadstring(game:HttpGet(url))()

    -- Tunggu UI muncul
    task.wait(0.4)

    -- Deteksi GUI baru & rename
    for _, container in pairs({game.CoreGui, LocalPlayer:WaitForChild("PlayerGui")}) do
        for _, gui in pairs(container:GetChildren()) do
            if not before[gui] then
                gui.Name = tag
                return gui
            end
        end
    end
end

local function removeUI(tag)
    for _, container in pairs({game.CoreGui, LocalPlayer:WaitForChild("PlayerGui")}) do
        local gui = container:FindFirstChild(tag)
        if gui then gui:Destroy() end
    end
end

