-- 🔹 Variabel global
local LocalPlayer = game.Players.LocalPlayer
local OriginalAnimations = {}
local currentAnimationActive = nil

-- 🔹 Fungsi simpan animasi asli
local function SaveOriginal(Animate)
    OriginalAnimations = {}
    for _, child in ipairs(Animate:GetDescendants()) do
        if child:IsA("Animation") then
            OriginalAnimations[child] = child.AnimationId
        end
    end
end

-- 🔹 Fungsi apply animasi baru
local function ApplyAnimation(Animate, Humanoid, pack)
    Animate.idle.Animation1.AnimationId = pack.idle1
    Animate.idle.Animation2.AnimationId = pack.idle2
    Animate.walk.WalkAnim.AnimationId = pack.walk
    Animate.run.RunAnim.AnimationId = pack.run
    Animate.jump.JumpAnim.AnimationId = pack.jump
    Animate.fall.FallAnim.AnimationId = pack.fall
    Animate.climb.ClimbAnim.AnimationId = pack.climb
    Animate.swim.Swim.AnimationId = pack.swim
    Animate.swimidle.SwimIdle.AnimationId = pack.swimidle
    Humanoid.Jump = true
end

-- 🔹 Fungsi restore animasi asli
local function RestoreOriginal()
    for anim, id in pairs(OriginalAnimations) do
        if anim and anim:IsA("Animation") then
            anim.AnimationId = id
        end
    end
    OriginalAnimations = {}
end

-- 🔹 Toggle animation pack di tab AnimTab
local animationInteracted = {}

for i, pack in ipairs(RunAnimations) do
    animationInteracted[pack.name] = false

    AnimTab:Toggle({
        Title = pack.name,
        Desc = "Apply " .. pack.name,
        Icon = "zap",
        Type = "Checkbox",
        Value = false,
        Callback = function(state)
            local Char = LocalPlayer.Character
            if Char and Char:FindFirstChild("Animate") and Char:FindFirstChild("Humanoid") then
                local Animate = Char.Animate
                local Humanoid = Char.Humanoid

                if state then
                    -- Uncheck toggle lain supaya cuma satu aktif
                    for _, otherPack in ipairs(RunAnimations) do
                        if otherPack.name ~= pack.name and animationInteracted[otherPack.name] then
                            animationInteracted[otherPack.name] = false
                            -- Update toggle UI
                            AnimTab:SetToggleState(otherPack.name, false)
                        end
                    end

                    SaveOriginal(Animate)
                    ApplyAnimation(Animate, Humanoid, pack)
                    currentAnimationActive = pack.name
                    animationInteracted[pack.name] = true
                    Notify(pack.name, "✅ Animation applied!", 3)
                else
                    RestoreOriginal()
                    currentAnimationActive = nil
                    if animationInteracted[pack.name] then
                        Notify(pack.name, "✅ Animation disabled!", 3)
                        animationInteracted[pack.name] = false
                    end
                end
            else
                if state then
                    Notify(pack.name, "❌ Character not found!", 3)
                end
            end
        end
    })

    if i % 6 == 0 and i < #RunAnimations then
        AnimTab:Space()
    end
end

