-- Calculate current avatar height (for route adjustment)
local function getCurrentHeight()
    local c = player.Character or player.CharacterAdded:Wait()
    local humanoid = c:WaitForChild("Humanoid")
    return humanoid.HipHeight + (c:FindFirstChild("Head") and c.Head.Size.Y or 2)
end

-- Adjust route frames vertically to match avatar height
local function adjustRoute(frames)
    local adjusted = {}
    local currentHeight = getCurrentHeight()
    local offsetY = currentHeight - DEFAULT_HEIGHT
    for _, cf in ipairs(frames) do
        local pos = cf.Position
        local rot = cf - pos
        local newPos = Vector3.new(pos.X, pos.Y + offsetY, pos.Z)
        table.insert(adjusted, CFrame.new(newPos) * rot)
    end
    return adjusted
end

-- Remove near-duplicate frames to reduce needless steps
local function removeDuplicateFrames(frames, tolerance)
    tolerance = tolerance or 0.01
    if #frames < 2 then return frames end
    local newFrames = { frames[1] }
    for i = 2, #frames do
        local prev = frames[i-1]
        local curr = frames[i]
        local prevPos, currPos = prev.Position, curr.Position
        local prevRot, currRot = prev - prev.Position, curr - curr.Position

        local posDiff = (prevPos - currPos).Magnitude
        -- Use rotation position as a proxy for rot difference
        local rotDiff = (prevRot.Position - currRot.Position).Magnitude

        if posDiff > tolerance or rotDiff > tolerance then
            table.insert(newFrames, curr)
        end
    end
    return newFrames
end

-- Interval rotation flip (face opposite) for each frame if enabled
local function applyIntervalRotation(cf)
    if intervalFlip then
        local pos = cf.Position
        local rot = cf - pos
        local newRot = CFrame.Angles(0, math.pi, 0) * rot
        return CFrame.new(pos) * newRot
    else
        return cf
    end
end

-- Load route from URL (expects a Lua file that returns an array of CFrame objects)
local function loadRoute(url)
    local ok, result = pcall(function()
        local code = game:HttpGet(url)
        return loadstring(code)()
    end)
    if ok and type(result) == "table" then
        -- Clean duplicates and adjust to current height
        local cleaned = removeDuplicateFrames(result, 0.01)
        local adjusted = adjustRoute(cleaned)
        return adjusted
    else
        warn("Failed to load route from: " .. tostring(url))
        return {}
    end
end

-- Find nearest route index among frames given current HRP position
local function getNearestFrameIndex(frames)
    local startIdx, dist = 1, math.huge
    if hrp then
        local pos = hrp.Position
        for i, cf in ipairs(frames) do
            local d = (cf.Position - pos).Magnitude
            if d < dist then
                dist = d
                startIdx = i
            end
        end
    end
    if startIdx >= #frames then
        startIdx = math.max(1, #frames - 1)
    end
    return startIdx
end

-- Smooth CFrame lerp with playbackRate & frameTime, honoring paused/isRunning
local function lerpCF(fromCF, toCF)
    fromCF = applyIntervalRotation(fromCF)
    toCF   = applyIntervalRotation(toCF)

    local duration = frameTime / math.max(0.05, playbackRate)
    local t = 0
    while t < duration do
        if not isRunning then break end
        while paused do task.wait() end
        local dt = task.wait()
        t = t + dt
        local alpha = math.min(t / duration, 1)
        if hrp and hrp.Parent and hrp:IsDescendantOf(workspace) then
            hrp.CFrame = fromCF:Lerp(toCF, alpha)
        end
    end
end

-- ---------- Bypass / Anti-Stuck ----------
local function setupBypass(char)
    local humanoid = char:WaitForChild("Humanoid")
    local rootPart = char:WaitForChild("HumanoidRootPart")
    local lastPos = rootPart.Position

    if bypassConn then bypassConn:Disconnect() end
    bypassConn = RunService.RenderStepped:Connect(function()
        if not rootPart or not rootPart.Parent then return end
        if bypassActive then
            local direction = (rootPart.Position - lastPos)
            local dist = direction.Magnitude

            -- small Y detection for jump/fall
            local yDiff = rootPart.Position.Y - lastPos.Y
            if yDiff > 0.5 then
                humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
            elseif yDiff < -1 then
                humanoid:ChangeState(Enum.HumanoidStateType.Freefall)
            end

            if dist > 0.01 then
                local moveVector = direction.Unit * math.clamp(dist * 5, 0, 1)
                humanoid:Move(moveVector, false)
            else
                humanoid:Move(Vector3.zero, false)
            end
        end
        lastPos = rootPart.Position
    end)
end
player.CharacterAdded:Connect(setupBypass)
if player.Character then setupBypass(player.Character) end

local function setBypass(state)
    bypassActive = state
    notify("Animation Bypass", state and "✅ Enabled" or "❌ Disabled", 2)
end

-- ---------- Anti-Beton (soft fall) ----------
local function enableAntiBeton()
    if antiBetonConn then antiBetonConn:Disconnect() end

    antiBetonConn = RunService.Stepped:Connect(function(_, dt)
        local c = player.Character
        if not c then return end
        local rootPart = c:FindFirstChild("HumanoidRootPart")
        local humanoid = c:FindFirstChild("Humanoid")
        if not rootPart or not humanoid then return end

        if antiBetonActive and humanoid.FloorMaterial == Enum.Material.Air then
            local targetY = -50
            local currentY = rootPart.Velocity.Y
            local newY = currentY + (targetY - currentY) * math.clamp(dt * 2.5, 0, 1)
            rootPart.Velocity = Vector3.new(rootPart.Velocity.X, newY, rootPart.Velocity.Z)
        end
    end)
end

local function disableAntiBeton()
    if antiBetonConn then
        antiBetonConn:Disconnect()
        antiBetonConn = nil
    end
end

-- ---------- Run / Stop / Loop logic ----------
local function runSelectedRouteOnce()
    if not selectedMountain then
        return notify("Error", "Please select a mountain first.", 3)
    end
    local frames = selectedFrames
    if not frames or #frames < 2 then
        return notify("Error", "No route loaded. Press Load Route first.", 3)
    end

    if not hrp then refreshHRP() end

    setBypass(true)
    isRunning = true
    paused = false

    local startIdx = getNearestFrameIndex(frames)
    logAndNotify("Starting route from index:", startIdx)

    for i = startIdx, #frames - 1 do
        if not isRunning then break end
        while paused do task.wait() end
        pcall(function() lerpCF(frames[i], frames[i+1]) end)
    end

    -- ✅ jangan matikan running kalau loop aktif
    if not loopRoute then
        isRunning = false
        setBypass(false)
    end
end

local function runSelectedRouteLoop()
    if not selectedMountain then return end
    isRunning = true
    paused = false

    while isRunning and loopRoute do
        if not selectedFrames or #selectedFrames < 2 then
            notify("Error", "Route not loaded.", 3)
            break
        end

        setBypass(true)

        local frames = selectedFrames
        local startIdx = getNearestFrameIndex(frames)

        for i = startIdx, #frames - 1 do
            if not isRunning or not loopRoute then break end
            while paused do task.wait() end
            pcall(function() lerpCF(frames[i], frames[i+1]) end)
        end

        -- ✅ setelah 1 putaran ulang lagi dari awal
        task.wait(1)
    end

    setBypass(false)
    isRunning = false
    paused = false
end

local function stopAllRoutes()
    if isRunning then
        logAndNotify("Stop route", "All routes stopped")
    end
    isRunning = false
    paused = false
    loopRoute = false
    if bypassActive then
        bypassActive = false
        notify("Animation Bypass", "❌ Disabled", 2)
    end
end

