local HttpService = game:GetService("HttpService")
local TeleportService = game:GetService("TeleportService")
local PlaceId = game.PlaceId
local Servers = {}
local serverButtonsCreated = false

local function Notify(title, content, time)
    WindUI:Notify({
        Title = title,
        Content = content,
        Icon = "globe",
        Time = time or 3
    })
end

local function FetchServers()
    local Cursor = ""
    Servers = {}
    local pageCount = 0

    repeat
        pageCount += 1
        local URL = string.format("https://games.roblox.com/v1/games/%s/servers/Public?sortOrder=Asc&limit=100%s",
            PlaceId, Cursor ~= "" and "&cursor="..Cursor or "")
        local success, response = pcall(function()
            return game:HttpGet(URL)
        end)

        if success then
            local Data = HttpService:JSONDecode(response)
            for _, server in pairs(Data.data) do
                table.insert(Servers, server)
            end
            Cursor = Data.nextPageCursor
        else
            Notify("Finding Server", "❌ Failed to fetch page " .. pageCount, 3)
            break
        end

        task.wait(0.3)
    until not Cursor or pageCount >= 5

    return Servers
end

