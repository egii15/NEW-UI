ServerTab:Button({
    Title = "🔍 START FIND SERVER",
    Desc = "Search for available servers (may take a moment)",
    Locked = false,
    Color = Color3.fromHex("#EC4899"),
    Justify = "Center",
    Callback = function()
        if serverButtonsCreated then
            Notify("Finding Server", "⚠️ Servers already loaded! Scroll down to see them.", 3)
            return
        end

        Notify("Finding Server", "🔄 Searching for servers... Please wait.", 3)

        task.spawn(function()
            local allServers = FetchServers()

            if #allServers == 0 then
                Notify("Finding Server", "❌ No servers found!", 4)
                return
            end

            ServerTab:Divider()
            ServerTab:Section({Title = "Available Servers (" .. #allServers .. " found)"})

            table.sort(allServers, function(a, b)
                return a.playing < b.playing
            end)

            for index, server in pairs(allServers) do
                local playerCount = string.format("%d/%d", server.playing, server.maxPlayers)
                local isSafe = server.playing <= (server.maxPlayers / 2)
                local emoji = isSafe and "🟢" or "🟥"
                local safety = isSafe and "Safe" or "Crowded"
                local name = string.format("%s [%s] - %s", emoji, playerCount, safety)

                ServerTab:Button({
                    Title = name,
                    Desc = "Server ID: " .. server.id .. " | Click to join",
                    Locked = false,
                    Color = Color3.fromHex("#EC4899"),
                    Justify = "Center",
                    Callback = function()
                        Notify("Teleporting", "🌐 Joining server... Please wait!", 3)
                        task.wait(1)
                        local success, err = pcall(function()
                            TeleportService:TeleportToPlaceInstance(PlaceId, server.id)
                        end)
                        if not success then
                            Notify("Teleporting", "❌ Failed to join: " .. tostring(err), 5)
                        end
                    end
                })

                if index % 5 == 0 then
                    ServerTab:Space()
                end
            end

            ServerTab:Divider()
            ServerTab:Paragraph({
                Title = "Search Complete",
                Description = "✅ Found " .. #allServers .. " servers!\n🟢 Green = Safe to join\n🟥 Red = Crowded"
            })

            Notify("Finding Server", "✅ Search complete! Found " .. #allServers .. " servers.", 4)
            serverButtonsCreated = true
        end)
    end
})

