local function SafeParent(gui)
    if syn and syn.protect_gui then
        pcall(function() syn.protect_gui(gui) end)
        gui.Parent = game.CoreGui
        return
    end
    if gethui then
        local ok,_ = pcall(function() gui.Parent = gethui() end)
        if ok then return end
    end
    gui.Parent = game.Players.LocalPlayer:WaitForChild("PlayerGui")
end

local function showScriptSelector(TRIAL_LINK, PERMA_LINK, FULLPACK_LINK)
    local player = game.Players.LocalPlayer

    -- Membuat ScreenGui
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "VIPSelector"
    SafeParent(screenGui)

    -- Membuat Frame utama
    local selectFrame = Instance.new("Frame", screenGui)
    selectFrame.Size = UDim2.new(0,280,0,200)
    selectFrame.Position = UDim2.new(0.5,-140,0.5,-100)
    selectFrame.BackgroundColor3 = Color3.fromRGB(25,25,25)
    selectFrame.BackgroundTransparency = 0.05
    Instance.new("UICorner", selectFrame).CornerRadius = UDim.new(0,15)

    -- Fungsi buat tombol
    local function makeButton(text, y, link)
        local btn = Instance.new("TextButton", selectFrame)
        btn.Size = UDim2.new(0.8, 0, 0, 36)
        btn.Position = UDim2.new(0.1, 0, y, 0)
        btn.Text = text
        btn.Font = Enum.Font.GothamBold
        btn.TextScaled = true
        btn.TextColor3 = Color3.fromRGB(255,255,255)
        btn.BackgroundColor3 = Color3.fromRGB(255,110,180)
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0,10)
        btn.MouseButton1Click:Connect(function()
            print("Tombol diklik:", text)
            selectFrame:Destroy()
            screenGui:Destroy()
            pcall(function() loadstring(game:HttpGet(link))() end)
        end)
    end

    -- Membuat tombol
    makeButton("🌸 Trial Script (3 Hari)", 0.1, TRIAL_LINK)
    makeButton("🌸 Permanent Script", 0.4, PERMA_LINK)
    makeButton("🌸 Developer Script", 0.7, FULLPACK_LINK)
end

