-- Whitelist
if game.Players.LocalPlayer.Name ~= "Miiraculouss" then
    game.Players.LocalPlayer:Kick("Not Whitelisted")
    return
end

local ModernV2 = loadstring(game:HttpGet("https://raw.githubusercontent.com/FayintXhub/FayintLibrary/refs/heads/main/YintUI"))()

-- Menu Icon (Kotak Open/Close)
local MenuIcon = ModernV2:CreateMenuIcon({
    Image = "grid",
    Size = 48,
    Draggable = true,
})

-- Window
local window = ModernV2:Window({
    Title = "LlyXCode",
    Content = "Private Script",
    Keybind = "RightControl",
    Search = false,
    ConfigEnabled = false,
    Loadingscreen = false,
})

window:AttachMenuIcon(MenuIcon)

-- Watermark
local Watermark = window:Watermark()
Watermark:SetRender(true)
Watermark:AddBlock("shield", "LlyXCode")
