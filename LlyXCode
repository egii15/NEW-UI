local Player = game:GetService("Players").LocalPlayer

-- Whitelist
if Player.Name ~= "Miiraculouss" then
    Player:Kick("Not Whitelisted")
    return
end

local ModernV2 = loadstring(game:HttpGet("https://raw.githubusercontent.com/FayintXhub/FayintLibrary/refs/heads/main/YintUI"))()

local window = ModernV2:Window({
    Title = "LlyXCode",
    Content = "Private",
    Keybind = "RightControl",
    Search = true,
    ConfigEnabled = false,
    Loadingscreen = false,
})

-- Watermark
local wm = window:Watermark()
wm:SetRender(true)
wm:AddBlock("code", "LlyXCode")

-- Function membuat tab
local function CreateTab(Name, Icon)
    local Tab = window:AddTab({
        Name = Name,
        Icon = Icon,
        Type = "Single",
    })

    local Section = Tab:AddSection({
        Name = Name,
        Position = "Center",
    })

    -- Toggle dummy
    for i = 1, 8 do
        Section:AddToggle({
            Name = "Toggle "..i,
            Default = false,
            Callback = function(Value)
                -- Tidak melakukan apa-apa
            end,
        })
    end
end

