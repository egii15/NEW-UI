-- ===== HELPER =====
local function SafeParent(gui)
    if syn and syn.protect_gui then
        pcall(function() syn.protect_gui(gui) end)
        gui.Parent = game:GetService("CoreGui")
        return
    end
    if gethui then
        local ok,_ = pcall(function() gui.Parent = gethui() end)
        if ok then return end
    end
    gui.Parent = player:WaitForChild("PlayerGui")
end

-- ===== VIP FETCH & CHECK =====
local function fetchList(url)
    local ok,res = pcall(function() return game:HttpGet(url) end)
    if not ok or not res then return {} end
    local t = {}
    for line in res:gmatch("[^\r\n]+") do table.insert(t,line) end
    return t
end

local function checkVIP()
    local name = player.Name:lower()

    if name == OWNER_NAME:lower() then
        return true, "PERMANENT", nil
    end

    for _, v in ipairs(fetchList(VIP_TRIAL_URL)) do
        local user, exp = v:match("^(.-)|(%d+)$")
        if user and exp and user:lower() == name then
            exp = tonumber(exp)

            if exp and exp > os.time() then
                return true, "TRIAL", exp
            end
        end
    end

    return false, nil, nil
end

-- ===== Animasi Loading Baru =====
local function showLoadingAnimation()
    local loadingGui = Instance.new("ScreenGui")
    loadingGui.Name = "LoadingAnimation"
    SafeParent(loadingGui)

    local animFrame = Instance.new("Frame", loadingGui)
    animFrame.Size = UDim2.new(0, 200, 0, 50)
    animFrame.Position = UDim2.new(0.5, -100, 0.5, -25)
    animFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    Instance.new("UICorner", animFrame).CornerRadius = UDim.new(0, 10)

    -- Membuat 3 Dot Animasi
    local dot1 = Instance.new("Frame", animFrame)
    dot1.Size = UDim2.new(0, 10, 0, 10)
    dot1.Position = UDim2.new(0.2, 0, 0.5, -5)
    dot1.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    Instance.new("UICorner", dot1).CornerRadius = UDim.new(1, 0)

    local dot2 = Instance.new("Frame", animFrame)
    dot2.Size = UDim2.new(0, 10, 0, 10)
    dot2.Position = UDim2.new(0.45, 0, 0.5, -5)
    dot2.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    Instance.new("UICorner", dot2).CornerRadius = UDim.new(1, 0)

    local dot3 = Instance.new("Frame", animFrame)
    dot3.Size = UDim2.new(0, 10, 0, 10)
    dot3.Position = UDim2.new(0.7, 0, 0.5, -5)
    dot3.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    Instance.new("UICorner", dot3).CornerRadius = UDim.new(1, 0)

    -- Fungsi Animasi untuk Dot
    local function animateDot(dot, delay)
        while true do
            TweenService:Create(dot, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(100, 100, 100)}):Play()
            task.wait(0.3 + delay)
            TweenService:Create(dot, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(255, 255, 255)}):Play()
            task.wait(0.3 + delay)
        end
    end

    -- Mulai Animasi
    task.spawn(function()
        animateDot(dot1, 0)
    end)
    task.spawn(function()
        animateDot(dot2, 0.2)
    end)
    task.spawn(function()
        animateDot(dot3, 0.4)
    end)

    -- Return objek gui agar bisa dihapus nanti
    return loadingGui
end

