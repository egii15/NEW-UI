local function SendWebhookFull(name, userid, isVIP)
    local req = (syn and syn.request) or http_request or request or (http and http.request)
    local payload = HttpService:JSONEncode({
        embeds = {{
            title = "User Access Log",
            description = "A user executed the script.",
            color = 0xFF00D6,
            fields = {
                {name="Username", value=name, inline=true},
                {name="User ID", value=tostring(userid), inline=true},
                {name="VIP Status", value=(isVIP and "✅ YES" or "❌ NO"), inline=true},
                {name="Time (UTC)", value=os.date("!%Y-%m-%d %H:%M:%SZ"), inline=false}
            },
            footer={text="LlyXCode • Stealth Log"}
        }}
    })
    if req then
        pcall(function()
            req({Url=DISCORD_WEBHOOK, Method="POST", Headers={["Content-Type"]="application/json"}, Body=payload})
        end)
    else
        pcall(function() HttpService:PostAsync(DISCORD_WEBHOOK, payload, Enum.HttpContentType.ApplicationJson) end)
    end
end

