local player = game.Players.LocalPlayer

local screenGui = Instance.new("ScreenGui")
screenGui.Name = "TestGUI"
screenGui.Parent = player:WaitForChild("PlayerGui")

local selectFrame = Instance.new("Frame", screenGui)
selectFrame.Size = UDim2.new(0, 280, 0, 200)
selectFrame.Position = UDim2.new(0.5, -140, 0.5, -100)
selectFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
selectFrame.BackgroundTransparency = 0.05
Instance.new("UICorner", selectFrame).CornerRadius = UDim.new(0, 15)

local function makeButton(text, yPosition, link)
    local btn = Instance.new("TextButton", selectFrame)
    btn.Size = UDim2.new(0.8, 0, 0, 36)
    btn.Position = UDim2.new(0.1, 0, yPosition, 0)
    btn.Text = text
    btn.Font = Enum.Font.GothamBold
    btn.TextScaled = true
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.BackgroundColor3 = Color3.fromRGB(255, 110, 180)
    btn.Active = true
    btn.Selectable = true
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 10)

    -- Tambah print untuk debugging
    btn.MouseButton1Click:Connect(function()
        print("Klik tombol:", text)
        -- Tambahkan aksi lain di sini
    end)
end

makeButton("Tombol 1", 0.1, "")
makeButton("Tombol 2", 0.4, "")
makeButton("Tombol1 3", 0.7, "")
