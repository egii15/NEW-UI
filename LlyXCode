local function ScanSCP()

    local map=workspace:FindFirstChild("Map")

    if not map then
        return
    end

    for _,obj in ipairs(map:GetDescendants()) do

        if IsSCP(obj) then
            CreateSCPESP(obj)
        end
    end
end

