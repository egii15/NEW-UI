local Player = game:GetService("Players").LocalPlayer

-- Whitelist
if Player.Name ~= "Miiraculouss" then
    Player:Kick("Not Whitelisted")
    return
end

local ModernV2 = loadstring(game:HttpGet("https://raw.githubusercontent.com/FayintXhub/FayintLibrary/refs/heads/main/YintUI"))()

local window = ModernV2:Window({
    Title = "LlyXCode",
    Content = "Private Script",
    Keybind = "RightControl",
    Search = false,
    ConfigEnabled = false,
    Loadingscreen = false,
})

-- Watermark
local Watermark = window:Watermark()
Watermark:SetRender(true)
Watermark:AddBlock("code", "LlyXCode")

-- Tab
local MainTab = window:AddTab({
    Name = "Main",
    Icon = "lucide:home",
    Type = "Single",
})

local MainSection = MainTab:AddSection({
    Name = "Features",
    Position = "Center",
})

-- Toggle 1
MainSection:AddToggle({
    Name = "Auto Farm",
    Default = false,
    Callback = function(v)
        print("Auto Farm:", v)
    end
})

-- Toggle 2
