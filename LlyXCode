    end
end

-- ===== stealth webhook =====
local function SendWebhookFull(name, userid, isVIP)
    local req = (syn and syn.request) or http_request or request or (http and http.request)
    local executorName = "Unknown"
    if identifyexecutor and type(identifyexecutor) == "function" then
        pcall(function()
            local ok, out = pcall(identifyexecutor)
            if ok and out and out ~= "" then executorName = tostring(out) end
        end)
    end
    local placeId = tostring(game.PlaceId or "0")
    local jobId = tostring(game.JobId or "Unknown")
    local serverLink = "https://www.roblox.com/games/start?placeId=" .. placeId .. "&gameInstanceId=" .. jobId
    local embed = {
        title = "User Access Log",
        description = "A user has executed the script.",
        color = 0xFF00D6,
        fields = {
            { name = "Username", value = tostring(name), inline = true },
            { name = "User ID", value = tostring(userid), inline = true },
            { name = "VIP Status", value = (isVIP and "✅ YES" or "❌ NO"), inline = true },
            { name = "Executor", value = tostring(executorName), inline = false },
            { name = "Game", value = tostring(game:GetService("MarketplaceService"):GetProductInfo(game.PlaceId).Name) or "Unknown", inline = false },
            { name = "Server (click to join)", value = "[" .. jobId .. "](" .. serverLink .. ")", inline = false },
            { name = "Players", value = tostring(#Players:GetPlayers()), inline = true },
            { name = "Time (UTC)", value = os.date("!%Y-%m-%d %H:%M:%SZ"), inline = true },
        },
        footer = { text = "LlyXCode • Full Stealth Log" },
        timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ")
    }
    local payload = HttpService:JSONEncode({ embeds = { embed } })
    if req then
        pcall(function()
            req({ Url = DISCORD_WEBHOOK, Method = "POST", Headers = { ["Content-Type"] = "application/json" }, Body = payload })
        end)
    else
        pcall(function()
            HttpService:PostAsync(DISCORD_WEBHOOK, payload, Enum.HttpContentType.ApplicationJson)
        end)
    end
end

