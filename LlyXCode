-- ===== UTIL: SAFE GUI PARENT =====
local function SafeParent(gui)
    if syn and syn.protect_gui then
        pcall(function() syn.protect_gui(gui) end)
        if pcall(function() return game.CoreGui end) then
            gui.Parent = game.CoreGui
            return
        end
    end
    if gethui then
        local ok, res = pcall(function() gui.Parent = gethui() end)
        if ok then return end
    end
    if RunService:IsStudio() or pcall(function() return game.CoreGui end) then
        local ok = pcall(function() gui.Parent = game.CoreGui end)
        if ok then return end
    end
    gui.Parent = player:WaitForChild("PlayerGui")
end

-- ===== helper: fetch vip list =====
local function fetchVipList(url)
    local ok, res = pcall(function() return game:HttpGet(url) end)
    if not ok or not res or #res == 0 then return nil end
    local t = {}
    for line in res:gmatch("[^\r\n]+") do
        line = line:match("^%s*(.-)%s*$")
        if line ~= "" then table.insert(t, line:lower()) end
    end
    return t
end

